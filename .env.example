# Copy this file to .env and fill in values for your local runs.
# Variables here are read by scripts/run_tests.sh and the Python libraries.

# Which environment YAML to load from config/environments/
TEST_ENV=dev

# Which browser config from config/browsers.yaml to use
BROWSER=chrome

# Set to true to route WebDriver sessions through Selenium Grid
USE_GRID=false

# Optional override for the grid URL (defaults to config/browsers.yaml)
# GRID_URL=http://localhost:4444/wd/hub
